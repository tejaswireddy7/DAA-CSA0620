#include <stdio.h>
#include <stdbool.h>

// Optimized Bubble Sort
void bubbleSort(int arr[], int n) {
    int i, j, temp;
    bool swapped;

    for (i = 0; i < n - 1; i++) {
        swapped = false;

        // Perform one pass
        for (j = 0; j < n - i - 1; j++) {
            if (arr[j] > arr[j + 1]) {
                // Swap elements
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
                swapped = true;
            }
        }

        // Print array after each pass
        printf("Pass %d: ", i + 1);
        for (int k = 0; k < n; k++) {
            printf("%d ", arr[k]);
        }
        printf("\n");

        // If no swaps occurred, array is already sorted
        if (!swapped) {
            break;
        }
    }
}

int main() {
    // Test Case 1
    int arr1[] = {64, 25, 12, 22, 11};
    int n1 = sizeof(arr1) / sizeof(arr1[0]);
    printf("Input: [64, 25, 12, 22, 11]\n");
    bubbleSort(arr1, n1);
    printf("Output: ");
    for (int i = 0; i < n1; i++) printf("%d ", arr1[i]);
    printf("\n\n");

    // Test Case 2
    int arr2[] = {29, 10, 14, 37, 13};
    int n2 = sizeof(arr2) / sizeof(arr2[0]);
    printf("Input: [29, 10, 14, 37, 13]\n");
    bubbleSort(arr2, n2);
    printf("Output: ");
    for (int i = 0; i < n2; i++) printf("%d ", arr2[i]);
    printf("\n\n");

    // Test Case 3
    int arr3[] = {3, 5, 2, 1, 4};
    int n3 = sizeof(arr3) / sizeof(arr3[0]);
    printf("Input: [3, 5, 2, 1, 4]\n");
    bubbleSort(arr3, n3);
    printf("Output: ");
    for (int i = 0; i < n3; i++) printf("%d ", arr3[i]);
    printf("\n\n");

    // Test Case 4 (Already sorted)
    int arr4[] = {1, 2, 3, 4, 5};
    int n4 = sizeof(arr4) / sizeof(arr4[0]);
    printf("Input: [1, 2, 3, 4, 5]\n");
    bubbleSort(arr4, n4);
    printf("Output: ");
    for (int i = 0; i < n4; i++) printf("%d ", arr4[i]);
    printf("\n\n");

    // Test Case 5 (Reverse sorted)
    int arr5[] = {5, 4, 3, 2, 1};
    int n5 = sizeof(arr5) / sizeof(arr5[0]);
    printf("Input: [5, 4, 3, 2, 1]\n");
    bubbleSort(arr5, n5);
    printf("Output: ");
    for (int i = 0; i < n5; i++) printf("%d ", arr5[i]);
    printf("\n");

    return 0;
}

