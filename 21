#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>

// Function to check if all elements are identical
bool all_identical(int arr[], int n) {
    for (int i = 1; i < n; i++) {
        if (arr[i] != arr[0]) {
            return false;
        }
    }
    return true;
}

// Function to check if all elements are negative
bool all_negative(int arr[], int n) {
    for (int i = 0; i < n; i++) {
        if (arr[i] >= 0) {
            return false;
        }
    }
    return true;
}

// Function to sort array (ascending order)
void sort_array(int arr[], int n) {
    for (int i = 0; i < n - 1; i++) {
        for (int j = i + 1; j < n; j++) {
            if (arr[i] > arr[j]) {
                int temp = arr[i];
                arr[i] = arr[j];
                arr[j] = temp;
            }
        }
    }
}

// Function to process list
void process_list(int arr[], int n) {
    if (n == 0) {
        printf("[]\n");
        return;
    }

    if (n == 1) {
        printf("[%d]\n", arr[0]);
        return;
    }

    if (all_identical(arr, n)) {
        printf("[");
        for (int i = 0; i < n; i++) {
            printf("%d", arr[i]);
            if (i < n - 1) printf(", ");
        }
        printf("]\n");
        return;
    }

    if (all_negative(arr, n)) {
        sort_array(arr, n);
        printf("[");
        for (int i = 0; i < n; i++) {
            printf("%d", arr[i]);
            if (i < n - 1) printf(", ");
        }
        printf("]\n");
        return;
    }

    // Default case
    printf("[");
    for (int i = 0; i < n; i++) {
        printf("%d", arr[i]);
        if (i < n - 1) printf(", ");
    }
    printf("]\n");
}

int main() {
    // Test Case 1: Empty list
    int arr1[] = {};
    process_list(arr1, 0);

    // Test Case 2: Single element
    int arr2[] = {1};
    process_list(arr2, 1);

    // Test Case 3: All identical
    int arr3[] = {7, 7, 7, 7};
    process_list(arr3, 4);

    // Test Case 4: Negative numbers
    int arr4[] = {-5, -1, -3, -2, -4};
    process_list(arr4, 5);

    return 0;
}


