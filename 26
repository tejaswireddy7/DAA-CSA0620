#include <stdio.h>

// Function to find a peak element index
int findPeakElement(int nums[], int n) {
    int left = 0, right = n - 1;

    while (left < right) {
        int mid = left + (right - left) / 2;

        // Compare mid with its next neighbor
        if (nums[mid] > nums[mid + 1]) {
            // Peak lies on the left side (including mid)
            right = mid;
        } else {
            // Peak lies on the right side
            left = mid + 1;
        }
    }

    // At the end, left == right → peak index
    return left;
}

int main() {
    // Example 1
    int arr1[] = {1, 2, 3, 1};
    int n1 = sizeof(arr1) / sizeof(arr1[0]);
    printf("Input: [1,2,3,1]\n");
    printf("Peak Index: %d\n\n", findPeakElement(arr1, n1)); // Expected: 2

    // Example 2
    int arr2[] = {1, 2, 1, 3, 5, 6, 4};
    int n2 = sizeof(arr2) / sizeof(arr2[0]);
    printf("Input: [1,2,1,3,5,6,4]\n");
    printf("Peak Index: %d\n", findPeakElement(arr2, n2)); // Expected: 1 or 5

    return 0;
}


OUTPUT-
Input: [1,2,3,1]
Peak Index: 2

Input: [1,2,1,3,5,6,4]
Peak Index: 5
